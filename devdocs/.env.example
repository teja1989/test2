# ── GitHub repos ─────────────────────────────────────────────────────────────
# JSON array: url (HTTPS or SSH), name (local folder), branch (default: main)
GITHUB_REPOS=[{"url":"https://github.com/org/service-platform.git","name":"service-platform","branch":"main"},{"url":"https://github.com/org/infra-platform.git","name":"infra-platform","branch":"main"}]

# GitHub PAT — repo (read) scope. Leave empty for SSH or public repos.
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Documentation ─────────────────────────────────────────────────────────────
DOCS_BASE_PATH=./repos

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Create an Azure AI Search resource, then copy the endpoint and admin key.
AZURE_SEARCH_ENDPOINT=https://your-instance.search.windows.net
AZURE_SEARCH_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX_NAME=devdocs

# ── Security ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme
# At least 32 random characters — used to sign session cookies
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:3001
# Public URL of the portal — used for auth redirects and Teams card links
APP_URL=http://localhost:5173

# ── Microsoft Teams notifications ─────────────────────────────────────────────
# Teams channel → Manage channel → Connectors → Incoming Webhook → Configure
# Leave blank to disable notifications.
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx/IncomingWebhook/yyy/zzz

# ── Azure Entra ID (SSO) ──────────────────────────────────────────────────────
# Register an app in Entra ID (App registrations → New registration).
# Set redirect URI to: http://localhost:3001/api/auth/callback
# Grant: User.Read (Microsoft Graph, delegated)
# Leave all four blank to run without authentication (open access).
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_SECRET=your-client-secret-value
AZURE_AD_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ── Azure OpenAI (Chat assistant) ─────────────────────────────────────────────
# Create a resource in Azure OpenAI Studio, then deploy a model.
# Leave AZURE_OPENAI_ENDPOINT blank to disable the chat assistant.
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
# Name of the deployed model (e.g. gpt-4o, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version — check Azure docs for latest stable version
AZURE_OPENAI_API_VERSION=2024-02-01
# Number of docs retrieved as RAG context per chat turn
CHAT_MAX_CONTEXT_DOCS=5
# Max tokens in the assistant's reply
CHAT_MAX_TOKENS=2048
