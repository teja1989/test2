# ── GitHub repos ────────────────────────────────────────────────────────────
# JSON array of objects: url (HTTPS or SSH), name (local folder), branch (default: main)
# HTTPS repos use GITHUB_PAT for auth; SSH repos use your SSH key as usual.
GITHUB_REPOS=[{"url":"https://github.com/org/service-platform.git","name":"service-platform","branch":"main"},{"url":"https://github.com/org/infra-platform.git","name":"infra-platform","branch":"main"}]

# GitHub Personal Access Token — needs repo (read) scope for private repos.
# Leave empty for public repos or when using SSH.
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Documentation paths ──────────────────────────────────────────────────────
DOCS_BASE_PATH=./repos

# ── Elasticsearch ────────────────────────────────────────────────────────────
ES_NODE=http://localhost:9200
ES_INDEX=devdocs

# ── Security ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Microsoft Teams notifications ────────────────────────────────────────────
# Incoming Webhook URL from Teams channel → Connectors → Incoming Webhook
# Leave blank to disable all Teams notifications.
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx/IncomingWebhook/yyy/zzz

# Public URL of the DevDocs frontend — adds an "Open DevDocs" button to cards
APP_URL=http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:3001
