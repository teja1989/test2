# Repository configuration — add REPO_N_URL / REPO_N_NAME pairs as needed
REPO_1_URL=git@github.com:org/service-platform.git
REPO_1_NAME=service-platform
REPO_2_URL=git@github.com:org/infra-platform.git
REPO_2_NAME=infra-platform

# Local path where repos are cloned
DOCS_BASE_PATH=./repos

# Elasticsearch
ES_NODE=http://localhost:9200
ES_INDEX=devdocs

# GitHub webhook HMAC secret
WEBHOOK_SECRET=changeme

# Backend server port
PORT=3001

# Frontend — base URL for the backend API (used by Vite proxy + client fetch)
VITE_API_BASE=http://localhost:3001
